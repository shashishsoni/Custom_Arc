{
  "name": "@customarc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd ../.. && bun --watch apps/api/src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build": "bun build src/index.ts --target bun --outdir dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@customarc/db": "workspace:*",
    "@customarc/design": "workspace:*",
    "@customarc/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.2",
    "@napi-rs/canvas": "^1.0.2",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.29",
    "react": "^19.2.8",
    "react-email": "^6.9.0",
    "resend": "^6.18.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/sharp": "^0.32.0",
    "typescript": "^6.0.3",
    "undici-types": "^8.8.0"
  }
