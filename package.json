{
  "name": "customarc",
  "version": "0.1.0",
  "private": true,
  "description": "CustomArc — Phase 1 buildable monorepo. See docs/phase-1/spec.md.",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install:all": "pnpm install",
    "deps:audit": "pnpm audit --prod --audit-level=high",
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @customarc/db migrate:dev",
    "db:seed": "pnpm --filter @customarc/db seed",
    "db:generate": "turbo generate",
    "api": "turbo dev --filter=@customarc/api",
    "web": "turbo dev --filter=@customarc/web"
  },
  "devDependencies": {
    "prettier": "^3.9.6",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  }
}
