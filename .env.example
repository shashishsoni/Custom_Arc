# CustomArc — single monorepo env (never commit). Copy to `.env` and fill.
# Backend = apps/api (server-only). Frontend = apps/web (NEXT_PUBLIC_* only reaches the browser).
# See docs/phase-1/spec.md §7 security baseline.

# =========================
# ---- shared ----
# =========================
DATABASE_URL="postgresql://customarc:customarc@localhost:5432/customarc?schema=public"
LOG_LEVEL="info"

# =========================
# ---- backend (apps/api) ----
# Server-only secrets. Do NOT use NEXT_PUBLIC_ here.
# =========================
API_PORT=3001
API_BASE_URL="http://localhost:3001"
WEB_BASE_URL="http://localhost:3000"

# Auth (better-auth, passwordless) — must be ≥32 chars; generate with `openssl rand -base64 32`
AUTH_SECRET="replace-me-use-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Object storage (Cloudflare R2) — private API access for uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="customarc-uploads"
# Optional server-side public/CDN base (r2.dev or custom domain). Not the S3 API host.
R2_PUBLIC_BASE_URL=""

# AI image generation (Cloudflare Workers AI primary; fal.ai fallback)
# Usage: dash.cloudflare.com → AI → Workers AI (Neurons / requests)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_TOKEN=""
FAL_KEY=""
# Credits spent per successful generation (idempotent via generation id)
AI_GENERATION_CREDIT_COST="1"

# Payments (Razorpay) — test keys from dashboard
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Print partner (chosen in ticket 12; Qikink/Printrove)
PRINT_PARTNER="qikink"
# Empty = sandbox submit (issue 17 proof). Set key later for live partner HTTP.
PRINT_PARTNER_API_KEY=""

# Moderation — AI auto-approves clean content; auto-rejects negative with reasons in DB.
# No manual queue. OPENAI_API_KEY and/or NVIDIA_API_KEY required for image scoring.
MODERATION_AUTO_APPROVE="true"
# Rare override: better-auth user ids allowed to POST /moderation/flags/:id/review
MODERATION_REVIEWER_IDS=""
# Email only when a paid order fails the print gate (not every upload).
MODERATION_NOTIFY_EMAIL=""
# Bulk lead form — defaults to MODERATION_NOTIFY_EMAIL if empty
LEADS_NOTIFY_EMAIL=""
# OpenAI Moderations + semantic (preferred). Empty = NVIDIA fallback.
OPENAI_API_KEY=""
# NVIDIA NIM fallback (build.nvidia.com)
NVIDIA_API_KEY=""
NVIDIA_MODERATION_MODEL="nvidia/nemotron-3.5-content-safety"
NVIDIA_SEMANTIC_MODEL="meta/llama-3.1-8b-instruct"

# Partner shipment webhooks (issue 18). Empty = allow only in development/sandbox.
FULFILLMENT_WEBHOOK_SECRET=""

# Email (Resend) — https://resend.com/api-keys
# Local/test: use onboarding@resend.dev (sends only to your Resend account email).
# Production: verify domain at https://resend.com/domains then set EMAIL_FROM to that domain.
RESEND_API_KEY=""
EMAIL_FROM="CustomArc <onboarding@resend.dev>"

# Monitoring
SENTRY_DSN=""

# =========================
# ---- frontend (apps/web) ----
# Only NEXT_PUBLIC_* is bundled into the browser. No secrets here.
# Loaded from this root file via apps/web/next.config.mjs
# =========================
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
# Public R2 CDN base for browser media (r2.dev or custom domain)
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=""
